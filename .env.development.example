NEXT_PUBLIC_VG_FEATURE_TRACK_EDITOR=1

# Required to enable the in-app Feedback FAB.
# A fine-grained personal access token scoped to Issues: read+write and
# Contents: read+write on the feedback repo (default Randroids-Dojo/VibeGear2).
# Leave unset locally to disable the route. The route returns 500 with code
# `server-misconfigured` when this is empty.
GITHUB_PAT=

# Optional: overrides the default repo `Randroids-Dojo/VibeGear2` that the
# Feedback FAB posts issues to. Useful when testing against a fork.
# FEEDBACK_REPO=Randroids-Dojo/VibeGear2
