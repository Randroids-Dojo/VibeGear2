{
  "name": "vibegear2",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Open source spiritual successor to Top Gear 2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "vite-node --script scripts/scrub-source-maps.ts",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bench:render": "vitest run --config vitest.bench.config.ts",
    "content-lint": "vite-node --script scripts/content-lint.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run content-lint",
    "verify:full": "npm run verify && npm run test:e2e"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
